{
	"name": "dom-flair",
	"version": "8.0.65",
	"description": "Stylesheet to solve `html` layout in intuitive ways, `<div flair='col grow center'></div>`. That's it.",
	"author": "Tito Bouzout, Kilo Spade",
	"main": "./css/index.css",
	"exports": {
		".": {
			"types": "./dom-flair.d.ts",
			"default": "./css/index.css"
		},
		"./reset": {
			"default": "./css/reset.css"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/titoBouzout/dom-flair.git"
	},
	"keywords": [
		"CSS",
		"Style",
		"Stylesheet",
		"Styled",
		"classes",
		"flair"
	],
	"bugs": {
		"url": "https://github.com/titoBouzout/dom-flair/issues"
	},
	"homepage": "https://github.com/titoBouzout/dom-flair#readme",
	"prettier": {
		"printWidth": 90,
		"useTabs": true,
		"semi": false,
		"singleQuote": true,
		"quoteProps": "as-needed",
		"jsxSingleQuote": false,
		"trailingComma": "all",
		"bracketSpacing": true,
		"bracketSameLine": false,
		"arrowParens": "avoid",
		"proseWrap": "never",
		"endOfLine": "lf"
	},
	"devDependencies": {
		"solid-js": "^1.9.3",
		"pota": "file:../pota/pota"
	}
}
